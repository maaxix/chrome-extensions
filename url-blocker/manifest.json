{
    "manifest_version": 3,
    "name": "URL & Popup Blocker",
    "version": "1.0",
    "description": "Blocks URLs and disables popups",
    "permissions": [
      "declarativeNetRequest",
      "declarativeNetRequestWithHostAccess",
      "storage",
      "scripting"
    ],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup/popup.html",
      "default_icon": {
        "16": "icons/icon0.png",
        "32": "icons/icon0.png",
        "48": "icons/icon0.png",
        "128": "icons/icon0.png"
      }
    },
    "icons": {
      "16": "icons/icon1.png",
      "32": "icons/icon1.png",
      "48": "icons/icon1.png",
      "128": "icons/icon1.png"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["scripts/blocker.js"],
        "run_at": "document_start",
        "all_frames": true,
        "match_about_blank": true
      }
    ],
    "web_accessible_resources": [{
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }]    
  }